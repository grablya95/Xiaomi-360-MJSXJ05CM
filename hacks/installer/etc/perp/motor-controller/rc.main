#!/bin/sh

POSITION_FILE="/mnt/data/config/position"

exec 2>&1
. ../.common/rc.main

## start target:
start() {
  echo "start motor controller daemon"

  . /mnt/data/config/config.sh 2>/dev/null
  [ "${PTZ_ENABLE:-off}" = "on" ] || exit 0

  cd /var/run
  [ ! -f ${POSITION_FILE} ] && echo "0 0 " > ${POSITION_FILE}
  ln -sf ${POSITION_FILE} /var/run/position

  exec /mnt/sdcard/hacks/motor-control/bin/motord.with-startup-calibration
}

eval ${TARGET} "$@"
